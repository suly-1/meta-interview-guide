# .npmrc — pnpm configuration
#
# save-exact: When you run `pnpm add <package>`, save the exact version
# (e.g., "1.2.3") instead of a range (e.g., "^1.2.3").
# This prevents silent breaking changes from minor/patch updates.
#
# To upgrade a specific package intentionally:
#   pnpm update <package>
# To upgrade all packages to latest (with review):
#   pnpm update --latest
save-exact=true

# Ensure the lockfile is always up to date — fail if it would change
# (Uncomment to enforce in CI)
# frozen-lockfile=true
