# .npmrc — pnpm configuration for meta-prep-guide
#
# save-exact: true
#   When you run `pnpm add <package>`, the version is pinned exactly (e.g. "1.2.3")
#   instead of using a range (e.g. "^1.2.3"). This prevents surprise breakage
#   from minor/patch updates that introduce regressions.
#   To upgrade a package intentionally: pnpm update <package>
#
save-exact=true

# audit-level: moderate
#   pnpm audit will fail CI if any dependency has a vulnerability at this
#   severity level or higher (low < moderate < high < critical).
#   Run manually: pnpm audit
#   Fix automatically: pnpm audit --fix
#
audit-level=moderate

# strict-peer-dependencies: false
#   Avoids install failures from peer dependency mismatches in the React ecosystem.
#   The template has carefully validated peer deps — keep this false.
#
strict-peer-dependencies=false
