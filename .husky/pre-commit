#!/usr/bin/env sh
# Pre-commit hook: format-check staged files, then run the full vitest suite.
# Full TypeScript type-check is run in CI (not pre-commit) to avoid blocking
# commits on pre-existing legacy TS issues in non-critical components.

# 1. Run lint-staged (prettier format check on staged files)
npx lint-staged

# 2. Run the full test suite — fast enough (~3s) to run on every commit
pnpm test
