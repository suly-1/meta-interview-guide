#!/usr/bin/env sh
# Pre-commit hook: format-check staged files, type-check the whole project,
# then run the full vitest suite.
# This prevents commits that introduce broken imports, undefined hooks,
# or failing smoke tests (e.g. the TopNav / SectionErrorBoundary regressions).

# 1. Run lint-staged (prettier format check on staged files)
npx lint-staged

# 2. Project-wide TypeScript type check (respects tsconfig.json)
pnpm check

# 3. Run the full test suite — fast enough (~2s) to run on every commit
pnpm test
